    maroPanel.Visible = false
    farmTab.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    maroTab.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
end)

maroTab.MouseButton1Click:Connect(function()
    farmPanel.Visible = false
    maroPanel.Visible = true
    farmTab.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    maroTab.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
end)

-- ========== УПРАВЛЕНИЕ ОКНОМ ==========
local function createMiniButton()
    if miniBtn then miniBtn:Destroy() end
    
    miniBtn = Instance.new("TextButton")
    miniBtn.Parent = screenGui
    miniBtn.Size = UDim2.new(0, 60, 0, 60)
    miniBtn.Position = UDim2.new(0, 20, 0, 100)
    miniBtn.Text = "📦"
    miniBtn.TextSize = 24
    miniBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    miniBtn.BorderSizePixel = 0
    roundCorners(miniBtn, 30)
    
    -- Перетаскивание мини-кнопки
    local draggingMini = false
    local dragStartMini, startPosMini
    local UIS = game:GetService("UserInputService")
    
    local function updateMiniPosition(input)
        local delta = input.Position - dragStartMini
        local newX = UDim2.new(0, startPosMini.X.Offset + delta.X, 0, startPosMini.Y.Offset + delta.Y)
        miniBtn.Position = newX
    end
    
    miniBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            draggingMini = true
            dragStartMini = input.Position
            startPosMini = miniBtn.Position
        end
    end)
    
    miniBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            draggingMini = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if draggingMini and (input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch) then
            updateMiniPosition(input)
        end
    end)
    
    miniBtn.MouseButton1Click:Connect(function()
        mainFrame.Visible = true
        miniBtn.Visible = false
    end)
    
    -- Для телефона: касание
    miniBtn.TouchTap:Connect(function()
        mainFrame.Visible = true
        miniBtn.Visible = false
    end)
end

closeBtn.MouseButton1Click:Connect(function()
    stopFarming()
    stopMaroSearch()
    screenGui:Destroy()
end)

minimizeBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    createMiniButton()
    miniBtn.Visible = true
end)

-- Перетаскивание основного окна
local dragging = false
local dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ========== ЗАПУСК ==========
farmToggle.MouseButton1Click:Connect(function()
    if isFarming then stopFarming() else startFarming() end
end)

maroStartBtn.MouseButton1Click:Connect(startMaroSearch)
maroStopBtn.MouseButton1Click:Connect(stopMaroSearch)

print("✅ DELIVERY HELPER v4.1 ЗАГРУЖЕН!")
print("📌 Мини-кнопку 📦 можно перетаскивать куда угодно")
