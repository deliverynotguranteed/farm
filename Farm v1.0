-- ========== ПЕРЕМЕННЫЕ ==========
local isFarming = false
local farmLoop = nil
local isSearchingMaro = false
local maroLoop = nil
local miniBtn = nil

-- ========== ФУНКЦИИ ДЛЯ ФАРМА ==========
local function pressAndHold(holdTime)
    holdTime = holdTime or 0.6
    local UIS = game:GetService("UserInputService")
    
    if UIS.TouchEnabled then
        local vu = game:GetService("VirtualUser")
        if vu then
            vu:CaptureController()
            vu:ClickButton1(Vector2.new(0, 0), true)
            task.wait(holdTime)
            vu:ClickButton1(Vector2.new(0, 0), false)
        else
            UIS:SetKeyDown(Enum.KeyCode.E)
            task.wait(holdTime)
            UIS:SetKeyUp(Enum.KeyCode.E)
        end
    else
        UIS:SetKeyDown(Enum.KeyCode.E)
        task.wait(holdTime)
        UIS:SetKeyUp(Enum.KeyCode.E)
    end
end

local function findNearestCargo(cargoName, radius, hrp)
    local nearest = nil
    local minDist = radius
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == cargoName and obj:IsA("BasePart") then
            local weld = obj:FindFirstChild("WeldConstraint")
            if not weld then
                local dist = (hrp.Position - obj.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

local function isCarryingCargo(cargoName, char, hrp)
    for _, obj in ipairs(char:GetDescendants()) do
        if obj.Name == cargoName and obj:IsA("BasePart") then
            local weld = obj:FindFirstChild("WeldConstraint")
            if weld and weld.Part1 == hrp then
                return true
            end
        end
    end
    return false
end

local function startFarming()
    if isFarming then return end
    
    local cargoName = cargoInput.Text
    local radius = tonumber(radiusInput.Text) or 20
    local deliveryPos = Vector3.new(
        tonumber(deliveryX.Text) or 0,
        tonumber(deliveryY.Text) or 3,
        tonumber(deliveryZ.Text) or 0
    )
    
    if not cargoName or cargoName == "" then
        farmStatus.Text = "❌ Укажи имя груза!"
        return
    end
    
    isFarming = true
    farmToggle.Text = "⏹ СТОП"
    farmToggle.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    farmStatus.Text = "🔄 Фарм запущен..."
    
    farmLoop = task.spawn(function()
        while isFarming do
            local char = player.Character
            if not char then task.wait(1); break end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(1); break end
            
            if not isCarryingCargo(cargoName, char, hrp) then
                local cargo = findNearestCargo(cargoName, radius, hrp)
                if cargo then
                    hrp.CFrame = CFrame.new(cargo.Position + Vector3.new(0, 2, 0))
                    task.wait(0.2)
                    pressAndHold(0.6)
                    farmStatus.Text = "📦 Взял " .. cargoName
                else
                    farmStatus.Text = "🔍 Ищу " .. cargoName
                end
            else
                hrp.CFrame = CFrame.new(deliveryPos)
                farmStatus.Text = "✨ Телепорт на сдачу"
            end
            task.wait(1)
        end
    end)
end

local function stopFarming()
    if not isFarming then return end
    isFarming = false
    if farmLoop then task.cancel(farmLoop) end
    farmToggle.Text = "▶ СТАРТ"
    farmToggle.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    farmStatus.Text = "⏹ Остановлен"
end

-- ========== ФУНКЦИИ ДЛЯ ПОИСКА CAPTAIN MARO ==========
local function isTransgressorPurchased()
    local stats = player:FindFirstChild("stats")
    if stats then
        local transgressorStat = stats:FindFirstChild("transgressor")
        if transgressorStat and transgressorStat.Value > 0 then
            return true
        end
    end
    return false
end

local function teleportToRandomSporewall()
    local MIN_DIST = 20000
    local MAX_DIST = 60000
    local angle = math.rad(math.random(0, 360))
    local distance = math.random(MIN_DIST, MAX_DIST)
    local x = math.cos(angle) * distance
    local z = math.sin(angle) * distance
    local y = 150
    
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(x, y, z)
    end
    return distance
end

local function findTransgressor()
    for _, obj in ipairs(workspace:GetDescendants()) do
        local name = obj.Name
        if name == "Transgressor" or 
           name == "CaptainMaro" or 
           name == "transgressor" or
           name:lower():find("transgressor") then
            return obj
        end
    end
    return nil
end

local function startMaroSearch()
    if isSearchingMaro then return end
    
    if isTransgressorPurchased() then
        maroStatus.Text = "❌ Transgressor уже куплен!"
        return
    end
    
    isSearchingMaro = true
    maroStartBtn.Visible = false
    maroStopBtn.Visible = true
    maroStatus.Text = "🔍 Поиск Captain Maro..."
    maroStatus.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
    
    maroLoop = task.spawn(function()
        local attempts = 0
        local MAX_ATTEMPTS = 20
        local WAIT_LOAD = 25
        
        while isSearchingMaro and attempts < MAX_ATTEMPTS do
            attempts = attempts + 1
            maroStatus.Text = "📍 Попытка " .. attempts .. "/" .. MAX_ATTEMPTS .. " | Телепорт..."
            
            local distance = teleportToRandomSporewall()
            maroStatus.Text = "📍 Попытка " .. attempts .. " | Дист: " .. distance .. " studs | Ждём 25 сек..."
            
            task.wait(WAIT_LOAD)
            
            if not isSearchingMaro then break end
            
            maroStatus.Text = "🔎 Поиск Transgressor..."
            local transgressor = findTransgressor()
            
            if transgressor then
                maroStatus.Text = "✅ НАШЁЛ Captain Maro!"
                maroStatus.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") and transgressor:IsA("BasePart") then
                    char.HumanoidRootPart.CFrame = CFrame.new(transgressor.Position + Vector3.new(0, 5, 0))
                end
                
                isSearchingMaro = false
                break
            else
                maroStatus.Text = "❌ Не нашёл. Продолжаю..."
            end
        end
        
        if isSearchingMaro and attempts >= MAX_ATTEMPTS then
            maroStatus.Text = "❌ Поиск завершён. Transgressor не найден."
            maroStatus.BackgroundColor3 = Color3.fromRGB(100, 50, 50)
        end
        
        maroStartBtn.Visible = true
        maroStopBtn.Visible = false
        isSearchingMaro = false
    end)
end

local function stopMaroSearch()
    if not isSearchingMaro then return end
    isSearchingMaro = false
    if maroLoop then task.cancel(maroLoop) end
    maroStatus.Text = "⏹ Поиск остановлен"
    maroStatus.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    maroStartBtn.Visible = true
    maroStopBtn.Visible = false
end

-- ========== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ==========
farmTab.MouseButton1Click:Connect(function()
